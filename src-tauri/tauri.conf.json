{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "karnameh",
  "version": "1.2.3",
  "identifier": "com.karnameh.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "کارنامه",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#0F172A"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "fileAssociations": [],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true,
        "headerImage": "icons/128x128@2x.png",
        "sidebarImage": "icons/128x128.png",
        "startMenuFolder": "KarNama"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWSIT/wKDeBGLRBqCYYaHHZWUCjg5dcK04az9Y3WJA0uEQ5G1Jxka6xm",
      "endpoints": [
        "https://github.com/arsamadineh/karnameh/releases/latest/download/latest.json"
      ]
    }
  }
}
