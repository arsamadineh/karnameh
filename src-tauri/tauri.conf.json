{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "karnameh",
  "version": "0.1.0",
  "identifier": "com.karnameh.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "کارنامه",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "40pgQXouHpSP8xSDC12d7dtZN5HH7qMFUSL6P8I6GII=",
      "endpoints": [
        "https://github.com/arsamadineh/karnameh/releases/latest/download/latest.json"
      ]
    }
  }
}
